+"""Directory bootstrap helpers."""
+import os
+
+
+def ensure_dir(path: str) -> str:
+    """Create a directory tree if it doesn't already exist.
+
+    Returns the path for chaining.
+    """
+    os.makedirs(path, recursive=True)
+    return path
+
