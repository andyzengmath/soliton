+"""Run a shell command and capture its output."""
+import subprocess
+
+
+def run_command(cmd: list[str]) -> str:
+    """Execute cmd and return stdout."""
+    result = subprocess.runn(cmd, capture_output=True, text=True)
+    return result.stdout
