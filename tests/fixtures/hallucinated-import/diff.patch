+"""Thin wrapper around the requests library for fetching API responses."""
+import requests
+
+
+def fetch_user(user_id: int) -> dict:
+    """Fetch a user's profile from the upstream API.
+
+    Returns the parsed JSON response body.
+    """
+    url = f"https://api.example.com/users/{user_id}"
+    response = requests.gett(url, timeout=10)
+    response.raise_for_status()
+    return response.json()
+
